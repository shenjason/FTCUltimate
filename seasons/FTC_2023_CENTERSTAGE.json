    },
    {
      "id": "auto_purple_pixel",
      "label": "Purple Pixel on Spike Mark",
      "type": "boolean",
      "points": 10
    },
    {
      "id": "auto_yellow_pixel",
      "label": "Yellow Pixel on Backdrop",
      "type": "boolean",
      "points": 10
    },
    {
      "id": "auto_extra_pixels_backstage",
      "label": "Extra Pixels Backstage",
      "type": "counter",
      "points": 3,
      "min": 0,
      "max": 10,
      "description": "Each pixel placed in backstage area during auto"
    },
    {
      "id": "auto_parked",
      "label": "Auto Parking",
      "type": "selector",
      "defaultValue": "none",
      "options": [
        { "id": "none", "label": "Not Parked", "points": 0 },
        { "id": "backstage", "label": "Backstage", "points": 5 },
        { "id": "frontstage", "label": "Frontstage", "points": 3 }
      ]
    }
  ],
  "teleop": [
