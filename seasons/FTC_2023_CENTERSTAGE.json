        { "id": "none", "label": "None", "points": 0 },
        { "id": "rigging", "label": "Rigging (Hanging)", "points": 20 }
      ]
    },
    {
      "id": "end_parked",
      "label": "Endgame Park",
      "type": "selector",
      "defaultValue": "none",
      "options": [
        { "id": "none", "label": "None", "points": 0 },
        { "id": "backstage", "label": "Backstage", "points": 5 },
        { "id": "frontstage", "label": "Frontstage", "points": 2 }
