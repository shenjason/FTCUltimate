          "points": 10
        },
        {
          "id": "set_line_bonus",
          "label": "Set Line Bonus",
          "description": "Pixels placed across a set line",
          "type": "manual_boolean",
          "points": 10
        }
      ]
    },
    {
      "id": "teleop_floor_pixels",
      "label": "Floor Pixels (Backstage)",
