{
  "expo": {
    "name": "FTCUltimate",
    "slug": "ftcultimate",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "ftcultimate",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ftcultimate.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.ftcultimate.app"
    },
    "plugins": ["expo-router", "expo-screen-orientation"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
